{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Secret Reference State",
  "description": "Standalone secret reference registry — extracted from Bootstrap State for federation-scoped secret management. Every secret is a reference (KeePass path), never a value. Used by Track 2 assessment (Phase 18).",
  "type": "object",
  "required": ["schema_version", "cell_id", "owning_cell", "declared_at"],
  "additionalProperties": false,
  "definitions": {
    "secret_ref_entry": {
      "type": "object",
      "required": ["id", "keepass_path"],
      "additionalProperties": true,
      "properties": {
        "id":           {"type": "string", "description": "Unique secret identifier"},
        "name":         {"type": ["string", "null"], "description": "Human-readable name"},
        "keepass_path": {"type": "string", "description": "KeePass path (never a value)"},
        "owning_cell":  {"type": "string", "description": "cell_id that owns this secret"},
        "category":     {"type": ["string", "null"], "description": "infrastructure, backup, k3s, service, external"},
        "used_by":      {"type": "array", "items": {"type": "string"}, "description": "Service or VM names that use this secret"},
        "rotation_policy": {
          "type": ["string", "null"],
          "enum": ["manual", "auto-90d", "auto-30d", "never", null]
        },
        "last_rotated_at": {"type": ["string", "null"], "format": "date-time"},
        "expires_at":      {"type": ["string", "null"], "format": "date-time"},
        "notes":           {"type": ["string", "null"]},
        "required_for_recovery": {
          "type": "boolean",
          "description": "If true, this secret must be available for reconstruction to proceed"
        }
      }
    }
  },
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "cell_id":     {"type": "string", "minLength": 1},
    "owning_cell": {"type": "string", "minLength": 1, "description": "Usually same as cell_id; differs for federated secrets"},
    "declared_at": {"type": "string", "format": "date-time"},
    "last_updated_at": {"type": ["string", "null"], "format": "date-time"},
    "collection_errors": {"type": "array", "items": {"type": "object"}},
    "secrets": {
      "type": "array",
      "items": {"$ref": "#/definitions/secret_ref_entry"},
      "description": "All secret references declared for this cell."
    },
    "recovery_critical_paths": {
      "type": "array",
      "items": {"type": "string"},
      "description": "KeePass paths that are required_for_recovery=true — must be available at reconstruction time."
    }
  }
}
